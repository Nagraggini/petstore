<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Properties>
        <Property name="basePath">logs</Property>
    </Properties>

    <Appenders>
        <!-- Fájlba írás időpecsétes névvel -->
        <RollingFile name="FileAppender" 
                     fileName="${basePath}/test-${date:yyyyMMdd-HHmmss}.log"
                     filePattern="${basePath}/test-%d{yyyyMMdd-HHmmss}-%i.log">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss} %-5level %logger - %msg%n"/>
            <Policies>
                <SizeBasedTriggeringPolicy size="10 MB"/>
            </Policies>
        </RollingFile>
    </Appenders>

    <Loggers>
        <Root level="INFO">
            <!-- Csak a FileAppender maradt, mivel a konzolt kivettük -->
            <AppenderRef ref="FileAppender"/>
        </Root>
    </Loggers>
</Configuration>